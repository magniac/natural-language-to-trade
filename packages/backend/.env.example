# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_PATH=./data/polymarket_agent.db

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Feature flags — ALL off by default
ENABLE_LIVE_TRADING=false
MAX_GLOBAL_LIVE_ORDER_USDC=1

# Polymarket
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com/
# Configure one relayer authorization method
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
# Alternative: Builder credentials
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# OpenRouter (backend-only — never expose to frontend or agent)
OPENROUTER_API_KEY=
# Override the model used for all LLM calls (default: anthropic/claude-3-haiku)
OPENROUTER_MODEL=

# KMS / signer mode: "dev" (local key, test only) | "kms"
SIGNER_MODE=dev

# Admin
ADMIN_API_KEY=

# Compliance
GEOBLOCK_ENABLED=true
BLOCKED_COUNTRY_CODES=US,GB

# Logging
LOG_LEVEL=info

# Browser origins allowed to call the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
